[
  {
    "id": "chatgpt",
    "name": "ChatGPT",
    "type": "openai_compatible",
    "base_url": "https://api.openai.com/v1",
    "api_key_env": "OPENAI_API_KEY",
    "model": "gpt-4o",
    "enabled": false,
    "network_required": true,
    "dependency_level": "high",
    "allowed_task_types": [
      "health_check",
      "statement_generate",
      "analysis_answer",
      "alternative_suggest",
      "risk_comment",
      "report_draft"
    ],
    "max_payload_policy": {
      "max_chars": 12000,
      "truncate_strategy": "deny_if_exceeds"
    },
    "sensitive_data_policy": {
      "send_secrets": false,
      "send_personal_data": false,
      "requires_user_confirmation_for_sensitive_context": true
    }
  },
